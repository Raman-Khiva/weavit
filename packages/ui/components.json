{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@workspace/ui/components",
    "utils": "@workspace/ui/lib/utils",
    "ui": "@workspace/ui/components",
    "lib": "@workspace/ui/lib",
    "hooks": "@workspace/ui/hooks"
  },
  "registries": {
    "@uitripled": "https://ui.tripled.work/r/{name}.json",
    "@kibo-ui": "https://www.kibo-ui.com/r/{name}.json",
    "@shadcnblocks": "https://shadcnblocks.com/r/{name}.json"
    ,
  "@shadcn-studio": "https://shadcnstudio.com/r/{style}/{name}.json",
  "@ss-components": "https://shadcnstudio.com/r/components/{style}/{name}.json",
  "@ss-blocks": "https://shadcnstudio.com/r/blocks/{style}/{name}.json",
  "@ss-themes": "https://shadcnstudio.com/r/themes/{name}.json"


  }
}
