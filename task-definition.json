{
  "containerDefinitions": [
    {
      "name": "api",
      "image": "345259854146.dkr.ecr.ap-south-1.amazonaws.com/weavit/api:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 4000,
          "hostPort": 4000,
          "protocol": "tcp",
          "name": "container-port-protocol",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "secrets": [
        {
          "name": "DOPPLER_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:345259854146:secret:weavit-api-dev-doppler-token-LHg6aE"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/weavit-api",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "family": "weavit-api",
  "executionRoleArn": "arn:aws:iam::345259854146:role/service-role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "enableFaultInjection": false
}
